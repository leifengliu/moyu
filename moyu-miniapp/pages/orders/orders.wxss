.header {
  background: #fff; border-bottom: 2rpx solid var(--color-border);
  position: sticky; top: 0; z-index: 100;
}
.header-content { padding: 24rpx 48rpx; }
.header-title { font-size: 40rpx; display: block; margin-bottom: 24rpx; }

.tabs { white-space: nowrap; display: flex; }
.tab-item {
  display: inline-block; padding: 16rpx 36rpx; border-radius: 16rpx;
  font-size: 28rpx; color: var(--color-text-gray); background: #fff;
  border: 2rpx solid var(--color-border); margin-right: 16rpx;
}
.tab-item.active { background: var(--color-dark); color: var(--color-gold); border-color: var(--color-dark); }

.order-list { padding: 32rpx 48rpx; }
.order-card {
  background: #fff; border-radius: 16rpx; border: 2rpx solid var(--color-border);
  padding: 32rpx; margin-bottom: 24rpx;
}
.order-header { display: flex; justify-content: space-between; margin-bottom: 24rpx; }
.order-no { font-size: 24rpx; color: var(--color-text-gray); }
.order-status { font-size: 24rpx; padding: 6rpx 20rpx; border-radius: 40rpx; }
.order-status.completed { background: var(--color-border); color: var(--color-text); }
.order-status.active { background: rgba(201,169,97,0.1); color: var(--color-gold); }

.order-item { display: flex; align-items: center; margin-bottom: 16rpx; }
.oi-name { font-size: 28rpx; flex: 1; }
.oi-qty { font-size: 24rpx; color: var(--color-text-gray); margin: 0 16rpx; }
.oi-price { font-size: 28rpx; }

.order-footer { display: flex; justify-content: space-between; border-top: 2rpx solid var(--color-border); padding-top: 24rpx; margin-top: 24rpx; }
.order-date { font-size: 24rpx; color: var(--color-text-gray); }
.order-total { display: flex; align-items: baseline; gap: 4rpx; }
.total-label { font-size: 24rpx; color: var(--color-text-gray); margin-right: 8rpx; }
.total-value { font-size: 36rpx; color: var(--color-gold); }

.order-actions { display: flex; gap: 16rpx; margin-top: 24rpx; }
.action-outline {
  flex: 1; text-align: center; padding: 20rpx 0;
  border: 2rpx solid var(--color-border); border-radius: 16rpx;
  font-size: 28rpx; color: var(--color-text-gray);
}
.action-primary {
  flex: 1; text-align: center; padding: 20rpx 0;
  background: var(--color-dark); color: var(--color-gold);
  border-radius: 16rpx; font-size: 28rpx;
}

.empty { text-align: center; padding-top: 200rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-gray); }
