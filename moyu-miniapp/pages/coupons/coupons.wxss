.header { border-bottom: 2rpx solid #222; }
.header-row { padding: 24rpx 48rpx; display: flex; align-items: center; }
.back-btn { width: 40rpx; height: 40rpx; margin-right: 24rpx; }
.header-title { font-size: 32rpx; color: #fff; letter-spacing: 4rpx; }

.coupon-list { padding: 32rpx 48rpx; }
.coupon-card { display: flex; background: #111; border: 2rpx solid #222; margin-bottom: 24rpx; }
.coupon-card.disabled { opacity: 0.4; }
.cc-left { width: 200rpx; padding: 40rpx 0; display: flex; flex-direction: column; align-items: center; justify-content: center; border-right: 2rpx dashed #333; }
.cc-value { font-size: 40rpx; color: var(--color-gold); font-weight: 500; }
.cc-cond { font-size: 22rpx; color: var(--color-text-gray); margin-top: 4rpx; }
.cc-right { flex: 1; padding: 32rpx; display: flex; flex-direction: column; justify-content: center; }
.cc-name { font-size: 30rpx; color: #fff; display: block; margin-bottom: 8rpx; }
.cc-date { font-size: 24rpx; color: var(--color-text-gray); display: block; margin-bottom: 12rpx; }
.cc-status { font-size: 24rpx; color: var(--color-gold); }
.cc-status.used { color: var(--color-text-gray); }
