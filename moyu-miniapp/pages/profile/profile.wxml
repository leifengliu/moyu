<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="status-bar-placeholder" style="height: {{statusBarHeight || 44}}px;"></view>
    <view class="header-info" bindtap="onProfileTap">
      <view class="avatar-box">
        <image class="avatar-img" src="{{userInfo.avatarUrl || ''}}" mode="aspectFill" wx:if="{{userInfo && userInfo.avatarUrl}}" />
        <text class="avatar-text" wx:else>摸</text>
      </view>
      <view class="user-info" wx:if="{{userInfo}}">
        <text class="user-name">{{userInfo.nickname || '摸鱼用户'}}</text>
        <text class="user-sub">已摸鱼 30 天</text>
      </view>
      <view class="user-info" wx:else catchtap="onLoginTap">
        <text class="user-name">点击登录</text>
      </view>
    </view>

    <view class="sign-in-btn" bindtap="onUpgrade" wx:if="{{!isMember}}">
      开通会员享专属优惠
    </view>
    <view class="sign-in-btn" bindtap="onSignIn" wx:else>
      每日签到 +10 积分
    </view>
  </view>

  <block wx:if="{{_anim}}">
  <!-- Stats -->
  <view class="stats-section anim-fade-up" style="animation-delay:0.05s">
    <view class="stats-card card">
      <view class="stat-item" wx:for="{{stats}}" wx:key="label" bindtap="onStatTap" data-path="{{item.path}}">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- Menu -->
  <view class="menu-section anim-fade-up" style="animation-delay:0.15s">
    <view class="menu-card card">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="label" bindtap="onMenuTap" data-path="{{item.path}}">
        <view class="menu-left">
          <image class="menu-icon" src="{{item.icon}}" mode="aspectFit" />
          <text class="menu-label">{{item.label}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
  </block>
</view>
