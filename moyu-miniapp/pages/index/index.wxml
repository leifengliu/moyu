<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="status-bar-placeholder" style="height: {{statusBarHeight || 44}}px;"></view>
    <view class="nav-bar">
      <text class="brand serif">摸鱼</text>
      <view style="width: 170rpx;"></view>
    </view>
  </view>

  <!-- Search Bar -->
  <view class="search-section">
    <view class="search-bar" bindtap="onSearchTap">
      <image class="search-icon" src="/images/search.svg" />
      <input class="search-input" placeholder="搜索咖啡、周边..." placeholder-style="color:var(--color-text-gray)" disabled="true" />
    </view>
  </view>

  <block wx:if="{{_anim}}">
  <!-- Banner Carousel -->
  <view class="banner-section anim-fade-up" style="animation-delay:0.1s" wx:if="{{banners.length > 0}}">
    <view class="banner">
      <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#fff" circular autoplay interval="4000" duration="500">
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <image class="banner-image" src="{{item.imageUrl}}" mode="aspectFill" />
        </swiper-item>
      </swiper>
    </view>
  </view>

  <!-- Quick Links -->
  <view class="quick-section">
    <view class="quick-card anim-fade-up link-menu" style="animation-delay:0.1s" bindtap="onQuickMenu">
      <image class="quick-icon" src="/images/tab-menu.png" mode="aspectFit" />
      <text class="quick-label">点单</text>
    </view>
    <view class="quick-card anim-fade-up link-shop" style="animation-delay:0.2s" bindtap="onQuickShop">
      <image class="quick-icon" src="/images/Merchandise.png" mode="aspectFit" />
      <text class="quick-label">商店</text>
    </view>
  </view>

  <!-- 饮品推荐 -->
  <view class="products-section" wx:if="{{drinks.length > 0}}">
    <view class="section-header anim-fade-in" style="animation-delay:0.3s">
      <text class="section-title serif">饮品推荐</text>
      <text class="section-sub">DRINKS</text>
    </view>
    <view class="product-grid">
      <view class="product-card anim-fade-up" wx:for="{{drinks}}" wx:key="id" wx:for-index="i" style="animation-delay:{{0.35 + i * 0.08}}s" bindtap="onProductTap" data-id="{{item.id}}">
        <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.basePrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 精选周边 -->
  <view class="products-section" wx:if="{{merch.length > 0}}">
    <view class="section-header anim-fade-in" style="animation-delay:0.3s">
      <text class="section-title serif">精选周边</text>
      <text class="section-sub">LIFESTYLE</text>
    </view>
    <view class="product-grid">
      <view class="product-card anim-fade-up" wx:for="{{merch}}" wx:key="id" wx:for-index="i" style="animation-delay:{{0.35 + i * 0.08}}s" bindtap="onProductTap" data-id="{{item.id}}">
        <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.basePrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  </block>
</view>
