<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="status-bar-placeholder" style="height: {{statusBarHeight || 44}}px;"></view>
    <view class="nav-bar">
      <text class="brand serif">摸鱼</text>
      <view style="width: 170rpx;"></view>
    </view>
  </view>

  <!-- Search Bar -->
  <view class="search-section">
    <view class="search-bar" bindtap="onSearchTap">
      <image class="search-icon" src="/images/search.svg" />
      <input class="search-input" placeholder="搜索咖啡、特调..." placeholder-style="color:rgba(255,255,255,0.5)" disabled="true" />
    </view>
  </view>

  <block wx:if="{{_anim}}">
  <!-- Banner -->
  <view class="banner-section anim-fade-up" style="animation-delay:0.1s">
    <view class="banner">
      <text class="banner-tag">EXCLUSIVE OFFER</text>
      <text class="banner-title serif">{{banner.title}}</text>
      <text class="banner-desc">{{banner.desc}}</text>
    </view>
  </view>

  <!-- Quick Links -->
  <view class="quick-section">
    <view class="quick-card anim-fade-up link-menu" style="animation-delay:0.1s" bindtap="onQuickMenu">
      <text class="quick-icon">☕</text>
      <text class="quick-label">点单</text>
    </view>
    <view class="quick-card anim-fade-up link-shop" style="animation-delay:0.2s" bindtap="onQuickShop">
      <text class="quick-icon">🛍</text>
      <text class="quick-label">商店</text>
    </view>
  </view>

  <!-- Products -->
  <view class="products-section">
    <view class="section-header anim-fade-in" style="animation-delay:0.3s">
      <text class="section-title serif">热门推荐</text>
      <text class="section-sub">FEATURED</text>
    </view>
    <view class="product-grid">
      <view class="product-card anim-fade-up" wx:for="{{products}}" wx:key="id" wx:for-index="i" style="animation-delay:{{0.35 + i * 0.08}}s" bindtap="onProductTap" data-id="{{item.id}}">
        <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <view class="product-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.basePrice}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  </block>
</view>
