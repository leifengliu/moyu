.container { padding-bottom: 220rpx; }

.header-content { padding: 24rpx 48rpx; display: flex; align-items: center; gap: 24rpx; }
.back-btn { width: 40rpx; height: 40rpx; }
.header-title { font-size: 36rpx; color: var(--color-text); font-family: 'Times New Roman', serif; flex: 1; }
.capsule-spacer { width: 174rpx; flex-shrink: 0; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-icon { font-size: 96rpx; margin-bottom: 32rpx; }
.empty-text { font-size: 28rpx; color: var(--color-text-gray); margin-bottom: 48rpx; }
.empty-btn { padding: 24rpx 80rpx; background: var(--color-dark); color: #fff; font-size: 28rpx; }

.cart-items { padding: 24rpx 48rpx; }
.cart-item { display: flex; gap: 20rpx; align-items: center; background: #fff; border: 2rpx solid var(--color-border); padding: 24rpx; margin-bottom: 20rpx; }
.item-image { width: 160rpx; height: 160rpx; flex-shrink: 0; background: var(--color-bg); }
.item-info { flex: 1; min-width: 0; }
.item-header { display: flex; justify-content: space-between; align-items: flex-start; }
.item-name-wrap { flex: 1; }
.item-name { font-size: 32rpx; color: var(--color-text); display: block; margin-bottom: 8rpx; }
.item-specs { font-size: 24rpx; color: var(--color-text-gray); }
.item-remove { font-size: 32rpx; padding: 8rpx; }
.item-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 24rpx; }
.qty-control { display: flex; align-items: center; gap: 16rpx; background: var(--color-bg); padding: 8rpx 16rpx; }
.qty-btn { width: 48rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.qty-val { width: 48rpx; text-align: center; font-size: 28rpx; }

.coupon-bar { margin: 24rpx 48rpx; background: #fff; border: 2rpx solid var(--color-border); padding: 24rpx; display: flex; justify-content: space-between; align-items: center; }
.coupon-left { display: flex; align-items: center; gap: 16rpx; }
.coupon-icon { font-size: 40rpx; }
.coupon-title { font-size: 28rpx; color: var(--color-text); display: block; }
.coupon-sub { font-size: 24rpx; color: var(--color-gold); }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 2rpx solid var(--color-border); padding: 24rpx 48rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); }
.bottom-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.total-label { font-size: 28rpx; color: var(--color-text-gray); }
.total-value { font-size: 52rpx; color: var(--color-dark); font-weight: 500; }
.checkout-btn { width: 100%; background: var(--color-dark); color: #fff; padding: 28rpx 0; text-align: center; font-size: 32rpx; }
