<view class="container" wx:if="{{isEmpty}}">
  <view class="header">
    <view class="status-bar-placeholder" style="height: {{statusBarHeight || 44}}px;"></view>
    <view class="header-content">
      <image class="back-btn" src="/images/back.svg" bindtap="onGoBack" />
      <text class="header-title serif">购物车</text>
      <view class="capsule-spacer"></view>
    </view>
  </view>
  <view class="empty-state">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车空空如也</text>
    <view class="empty-btn" bindtap="onGoMenu">去点单</view>
  </view>
</view>

<view class="container" wx:else>
  <view class="header">
    <view class="status-bar-placeholder" style="height: {{statusBarHeight || 44}}px;"></view>
    <view class="header-content">
      <image class="back-btn" src="/images/back.svg" bindtap="onGoBack" />
      <text class="header-title serif">购物车{{totalItems > 0 ? ' · ' + totalItems + '件' : ''}}</text>
      <view class="capsule-spacer"></view>
    </view>
  </view>

  <!-- Items -->
  <view class="cart-items">
    <view class="cart-item" wx:for="{{items}}" wx:key="id">
      <view class="item-check" bindtap="onCheckToggle" data-id="{{item.id}}">
        <view class="checkbox {{item.checked ? 'checked' : ''}}"></view>
      </view>
      <image class="item-image" src="{{item.productImage}}" mode="aspectFill" />
      <view class="item-info">
        <view class="item-header">
          <view class="item-name-wrap">
            <text class="item-name">{{item.productName}}</text>
            <text class="item-specs">{{item.size}} / {{item.temp}} / {{item.sugar}}</text>
          </view>
          <view class="item-remove" bindtap="onRemove" data-id="{{item.id}}">🗑</view>
        </view>
        <view class="item-bottom">
          <view class="item-price">
            <text class="price-symbol">¥</text><text class="price-value">{{item.price}}</text>
          </view>
          <view class="qty-control">
            <view class="qty-btn" bindtap="onMinus" data-item="{{item}}">−</view>
            <text class="qty-val">{{item.quantity}}</text>
            <view class="qty-btn" bindtap="onPlus" data-item="{{item}}">+</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Coupon -->
  <view class="coupon-bar">
    <view class="coupon-left">
      <text class="coupon-icon">🎫</text>
      <view>
        <text class="coupon-title">优惠券</text>
        <text class="coupon-sub">3 张可用</text>
      </view>
    </view>
    <text class="coupon-arrow">›</text>
  </view>

  <!-- Bottom Bar -->
  <view class="bottom-bar">
    <view class="bottom-total">
      <text class="total-label">合计</text>
      <view class="total-price">
        <text class="price-symbol">¥</text><text class="total-value">{{totalAmount}}</text>
      </view>
    </view>
    <view class="checkout-btn" bindtap="onCheckout">去结算</view>
  </view>
</view>
