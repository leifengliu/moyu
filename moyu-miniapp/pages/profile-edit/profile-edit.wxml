<view class="container">
  <view class="page-header">
    <view class="status-bar" style="height: {{statusBarHeight || 44}}px;"></view>
    <view class="top-row">
      <image class="back-btn" src="/images/back.svg" bindtap="onGoBack" />
    </view>
  </view>

  <!-- Avatar -->
  <view class="avatar-section">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <view class="avatar-circle">
        <image wx:if="{{tempAvatarUrl || userInfo.avatarUrl}}" class="avatar-img" src="{{tempAvatarUrl || userInfo.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="avatar-letter">摸</text>
      </view>
      <view class="camera-badge">📷</view>
    </button>
    <text class="avatar-hint">点击更换头像</text>
  </view>

  <!-- Fields -->
  <view class="form-sec">
    <view class="field-block">
      <text class="field-label">昵称</text>
      <input class="field-input-box" value="{{editNickname}}" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>
    <view class="field-block">
      <text class="field-label">手机号</text>
      <view class="field-display">
        <text>{{userInfo.phone ? userInfo.phone.substring(0,3) + '****' + userInfo.phone.substring(7) : '未绑定'}}</text>
        <text class="field-link">更换 ›</text>
      </view>
    </view>
    <view class="field-block">
      <text class="field-label">性别</text>
      <view class="gender-group">
        <view class="gender-btn {{editGender === '男' ? 'active' : ''}}" bindtap="onGenderTap" data-gender="男">男</view>
        <view class="gender-btn {{editGender === '女' ? 'active' : ''}}" bindtap="onGenderTap" data-gender="女">女</view>
      </view>
    </view>
    <view class="field-block">
      <text class="field-label">生日</text>
      <picker mode="date" value="{{editBirthday || '2000-01-01'}}" bindchange="onBirthdayChange">
        <view class="field-input-box">{{editBirthday || '请选择生日'}}</view>
      </picker>
    </view>
  </view>

  <!-- Account Info -->
  <view class="account-card">
    <text class="acct-title">👤 账户信息</text>
    <text class="acct-row">注册时间：2026年3月1日</text>
    <text class="acct-row">最后登录：2026年6月3日</text>
  </view>

  <!-- Logout -->
  <view class="logout-section">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>
</view>
