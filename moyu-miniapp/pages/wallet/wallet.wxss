.header { border-bottom: 2rpx solid #222; }
.header-content { padding: 0 48rpx 24rpx; display: flex; align-items: center; gap: 24rpx; }
.capsule-spacer { width: 174rpx; flex-shrink: 0; }
.back-btn { width: 40rpx; height: 40rpx; }
.header-title { font-size: 36rpx; color: #fff; }

.balance-card { margin: 32rpx 48rpx; padding: 56rpx 48rpx; background: linear-gradient(135deg, #FF9B85, #FFA07A); border-radius: 32rpx; color: #fff; }
.balance-label { font-size: 28rpx; opacity: 0.9; display: block; margin-bottom: 8rpx; }
.balance-value { font-size: 72rpx; display: block; }

.packages-section { padding: 24rpx 48rpx; }
.section-title { font-size: 32rpx; color: #fff; display: block; margin-bottom: 24rpx; }
.package-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20rpx; }
.package-card { background: #111; padding: 40rpx 24rpx; text-align: center; border: 2rpx solid #333; position: relative; }
.package-card.recommend { border-color: #FF9B85; }
.pkg-badge { position: absolute; top: -16rpx; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg, #FF9B85, #FFA07A); color: #fff; font-size: 22rpx; padding: 6rpx 24rpx; border-radius: 40rpx; }
.pkg-amount { font-size: 40rpx; color: #fff; display: block; margin-bottom: 8rpx; }
.pkg-bonus { font-size: 24rpx; color: #FF9B85; }

.tx-section { padding: 24rpx 48rpx; }
.tx-list { background: #111; border: 2rpx solid #333; overflow: hidden; }
.tx-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; border-bottom: 2rpx solid #333; }
.tx-item:last-child { border-bottom: none; }
.tx-desc { font-size: 28rpx; color: #fff; display: block; margin-bottom: 4rpx; }
.tx-date { font-size: 24rpx; color: var(--color-text-gray); }
.tx-amount { font-size: 32rpx; color: #fff; }
.tx-amount.plus { color: #FF9B85; }
