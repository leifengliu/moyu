.header { background: #fff; border-bottom: 2rpx solid var(--color-border); }
.header-bar { padding: 24rpx 48rpx; display: flex; align-items: center; }
.back-btn { width: 40rpx; height: 40rpx; margin-right: 24rpx; }
.header-title { font-size: 32rpx; letter-spacing: 4rpx; }

.hero { background: linear-gradient(135deg, var(--color-dark), #6B4F3E); padding: 80rpx 48rpx; text-align: center; }
.hero-title { font-size: 52rpx; color: #fff; display: block; margin-bottom: 16rpx; }
.hero-desc { font-size: 26rpx; color: rgba(255,255,255,0.8); }

.section { padding: 0 48rpx; margin-top: 48rpx; }
.sec-title { font-size: 28rpx; color: var(--color-text); font-weight: 500; margin-bottom: 24rpx; display: block; }

.benefits-card { background: #fff; border: 2rpx solid var(--color-border); padding: 40rpx 32rpx; }
.benefit-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 28rpx; font-size: 28rpx; }
.benefit-row:last-child { margin-bottom: 0; }
.check-box { width: 40rpx; height: 40rpx; background: var(--color-dark); color: #fff; font-size: 22rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

.plan-card { background: #fff; border: 4rpx solid var(--color-border); padding: 36rpx 32rpx; margin-bottom: 20rpx; display: flex; justify-content: space-between; align-items: center; position: relative; }
.plan-card.popular { border-color: var(--color-dark); }
.plan-badge { position: absolute; top: -20rpx; left: 50%; transform: translateX(-50%); background: var(--color-dark); color: #fff; font-size: 22rpx; padding: 6rpx 32rpx; }
.plan-name { font-size: 32rpx; color: var(--color-text); font-weight: 500; display: block; margin-bottom: 6rpx; }
.plan-desc { font-size: 24rpx; color: var(--color-text-gray); display: block; }
.plan-discount { font-size: 24rpx; color: var(--color-gold); display: block; margin-top: 4rpx; }
.pp-symbol { font-size: 24rpx; color: var(--color-text-gray); }
.pp-value { font-size: 52rpx; color: var(--color-dark); font-weight: 500; }
.pp-period { font-size: 24rpx; color: var(--color-text-gray); }

.cta-sec { padding: 48rpx 48rpx 80rpx; }
.cta-btn { background: var(--color-dark); color: #fff; padding: 28rpx 0; text-align: center; font-size: 32rpx; }
.cta-note { font-size: 24rpx; color: var(--color-text-gray); text-align: center; margin-top: 24rpx; display: block; }
