.container { padding-bottom: 180rpx; }

.header-actions { padding: 0 48rpx 24rpx; }
.back-btn { width: 40rpx; height: 40rpx; }

.product-image-section { padding: 24rpx 48rpx; }
.product-image { width: 100%; height: 700rpx; background: #F5F5F3; border: 2rpx solid var(--color-border); }

.product-info-section { padding: 24rpx 48rpx; }
.info-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.product-name { font-size: 48rpx; color: var(--color-text); max-width: 60%; font-family: 'Times New Roman', serif; }
.product-desc { font-size: 28rpx; color: var(--color-text-gray); line-height: 1.6; }

.specs-section { padding: 24rpx 48rpx; }
.spec-group { margin-bottom: 48rpx; }
.spec-label { font-size: 26rpx; color: var(--color-text); letter-spacing: 4rpx; margin-bottom: 24rpx; display: block; }
.spec-options { display: flex; gap: 20rpx; }
.spec-options.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); }
.spec-option { flex: 1; padding: 24rpx 0; text-align: center; border: 2rpx solid var(--color-border); font-size: 28rpx; color: var(--color-text-gray); background: #fff; }
.spec-option.active { background: var(--color-dark); color: #fff; border-color: var(--color-dark); }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 2rpx solid var(--color-border); padding: 24rpx 48rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; gap: 24rpx; }
.quantity-control { display: flex; align-items: center; gap: 20rpx; background: var(--color-bg); padding: 16rpx 24rpx; }
.qty-btn { width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; }
.qty-value { width: 56rpx; text-align: center; font-size: 32rpx; font-weight: 500; }
.add-cart-btn { flex: 1; background: var(--color-dark); color: #fff; padding: 28rpx 0; text-align: center; font-size: 32rpx; }
