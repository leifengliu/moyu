<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="status-bar-placeholder" style="height: {{statusBarHeight || 44}}px;"></view>
    <view class="header-actions">
      <image class="back-btn" src="/images/back.svg" bindtap="onGoBack" />
    </view>
  </view>

  <!-- Image Carousel -->
  <view class="product-image-section">
    <swiper wx:if="{{product.images && product.images.length > 1}}" class="product-swiper" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#fff" circular autoplay="{{false}}">
      <swiper-item wx:for="{{product.images}}" wx:key="*this">
        <image class="product-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
    <image wx:else class="product-image-single" src="{{product.imageUrl}}" mode="aspectFill" />
  </view>

  <!-- Info -->
  <view class="product-info-section">
    <view class="info-row">
      <text class="product-name">{{product.name}}</text>
      <view class="price-row">
        <text class="price-symbol">¥</text><text class="price-value">{{currentPrice}}</text>
      </view>
    </view>
    <text class="product-desc">{{product.description}}</text>
  </view>

  <!-- Dynamic Spec Options -->
  <view class="specs-section">
    <view class="spec-group" wx:for="{{specs}}" wx:key="specType">
      <text class="spec-label">{{item.specType}}</text>
      <view class="spec-options {{item.options.length === 4 ? 'grid-4' : ''}}">
        <view wx:for="{{item.options}}" wx:key="specValue" wx:for-item="opt"
          class="spec-option {{opt.active ? 'active' : ''}}"
          bindtap="onSpecTap" data-spec-type="{{item.specType}}" data-spec-value="{{opt.specValue}}" data-selection-type="{{item.selectionType || 'SINGLE'}}">
          <text>{{opt.specValue}}</text>
          <text wx:if="{{opt.priceAdjust > 0}}" class="spec-price-adjust">+¥{{opt.priceAdjust}}</text>
          <text wx:if="{{opt.priceAdjust < 0}}" class="spec-price-adjust min">¥{{opt.priceAdjust}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Bottom Bar -->
  <view class="bottom-bar">
    <view class="quantity-control">
      <view class="qty-btn" bindtap="onMinus">−</view>
      <text class="qty-value">{{quantity}}</text>
      <view class="qty-btn" bindtap="onPlus">+</view>
    </view>
    <view class="add-cart-btn" bindtap="onAddToCart">
      加入购物车 · ¥{{totalPrice}}
    </view>
  </view>
</view>
